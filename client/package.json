{
    "name": "php-ci",
    "displayName": "PHP intellisense for codeigniter",
    "description": "Code completion for PHP codeigniter framework",
    "author": "Small",
    "license": "MIT",
    "version": "1.1.0",
    "publisher": "small",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "PHP",
        "codeigniter"
    ],
    "icon": "image/CI.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/smallp/vscode-ci.git"
    },
    "bugs": {
        "url": "https://github.com/smallp/vscode-ci/issues"
    },
    "activationEvents": [
        "onLanguage:php",
        "onCommand:extension.refreshModel"
    ],
    "main": "./out/src/extension",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "CI autoload",
            "properties": {
                "CI.ignoreSymbols": {
                    "type": "boolean",
                    "default": false,
                    "description": "Set true if you are using other extension to display symbols, deal with $this, and static vars."
                },
                "CI.model": {
                    "type": [
                        "array",
                        "object"
                    ],
                    "default": [],
                    "description": "Auto load models. Eg: ['user/account'] or {'whatilike':'Ori_model'} for alisa"
                },
                "CI.library": {
                    "type": [
                        "array",
                        "object"
                    ],
                    "default": [],
                    "description": "Auto load library. Eg: ['user','foo/account'] or {'whatilike':'Ori_library'} for alisa"
                },
                "CI.other": {
                    "type": "array",
                    "default": [
                        "system/core/Common.php"
                    ],
                    "description": "Path of files that need parse. That is just for addition const support."
                },
                "CI.system": {
                    "type": "string",
                    "default": "system",
                    "description": "Path of CI's system folder."
                },
                "CI.app": {
                    "type": "string",
                    "default": "application",
                    "description": "Path of CI's application folder."
                },
                "CI.viewFilesFormat": {
                    "type": "string",
                    "default": "php",
                    "description": "File format of view files. Eg: php or tpl or twig"
                }
            }
        },
        "commands": [
            {
                "command": "extension.refreshModel",
                "title": "CI: refresh Model"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -w -p ./",
        "build:extension": "yarn --cwd ../server run webpack-pro && yarn run compile",
        "sync:license": "node -e \"require('fs').copyFileSync('../LICENSE', './LICENSE')\"",
        "package:vsix": "yarn run build:extension && yarn run sync:license && npx @vscode/vsce package"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.17.57",
        "@types/vscode": "^1.85.0",
        "ts-loader": "^9.5.2",
        "typescript": "^5.8.3"
    }
}
